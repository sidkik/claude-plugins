#!/usr/bin/env bash
# crew-codex — forward to the official codex plugin's companion runtime.
# Resolves the runtime through installed_plugins.json so version bumps of
# codex@openai-codex never break the crew agents.
set -euo pipefail

CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
INSTALLED_JSON="$CLAUDE_DIR/plugins/installed_plugins.json"
CODEX_PLUGIN_ID="codex@openai-codex"

if ! command -v node >/dev/null 2>&1; then
  echo "crew-codex: node is required (the codex companion runtime is a Node script)" >&2
  exit 1
fi

if [[ ! -f "$INSTALLED_JSON" ]]; then
  echo "crew-codex: $INSTALLED_JSON not found — install the official Codex plugin first: /plugin install $CODEX_PLUGIN_ID" >&2
  exit 1
fi

if ! COMPANION_ROOT="$(node -e '
  const fs = require("fs");
  const data = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
  const entries = (data.plugins || {})[process.argv[2]];
  if (!Array.isArray(entries) || entries.length === 0 || !entries[0].installPath) process.exit(2);
  process.stdout.write(entries[0].installPath);
' "$INSTALLED_JSON" "$CODEX_PLUGIN_ID")"; then
  echo "crew-codex: $CODEX_PLUGIN_ID is not installed — run: /plugin install $CODEX_PLUGIN_ID" >&2
  exit 1
fi

COMPANION="$COMPANION_ROOT/scripts/codex-companion.mjs"
if [[ ! -f "$COMPANION" ]]; then
  echo "crew-codex: companion script missing at $COMPANION — the codex plugin layout changed; update codex-crew's resolver" >&2
  exit 1
fi

# Job state must land in the codex plugin's data dir so /codex:status,
# /codex:result and its SessionEnd cleanup see crew-launched jobs too.
export CLAUDE_PLUGIN_DATA="${CLAUDE_PLUGIN_DATA:-$CLAUDE_DIR/plugins/data/codex-openai-codex}"

if [[ "${1:-}" == "--resolve" ]]; then
  echo "$COMPANION"
  exit 0
fi

# Bounded retry on model-capacity rejection. The capacity error is an
# admission-time rejection (the turn never starts), so retrying is write-safe.
# Jittered backoff so parallel fan-outs don't thundering-herd the quota window.
# Overridable for tests: CREW_CODEX_RETRY_DELAYS="0 0" collapses the waits.
RETRY_DELAYS=(${CREW_CODEX_RETRY_DELAYS:-5 15 45})
MAX_ATTEMPTS=$(( ${#RETRY_DELAYS[@]} + 1 ))
CAPACITY_PATTERN="at capacity"

TMP_OUT="$(mktemp)" TMP_ERR="$(mktemp)"
trap 'rm -f "$TMP_OUT" "$TMP_ERR"' EXIT

attempt=1
while :; do
  rc=0
  node "$COMPANION" "$@" >"$TMP_OUT" 2>"$TMP_ERR" || rc=$?

  if [[ $rc -eq 0 ]] || ! grep -qi "$CAPACITY_PATTERN" "$TMP_OUT" "$TMP_ERR"; then
    break
  fi

  if [[ $attempt -ge $MAX_ATTEMPTS ]]; then
    echo "crew-codex: model still at capacity after $MAX_ATTEMPTS attempts — giving up" >&2
    break
  fi

  base=${RETRY_DELAYS[$((attempt - 1))]}
  delay=$(( base + (base > 0 ? RANDOM % (base / 2 + 1) : 0) ))
  echo "crew-codex: model at capacity (attempt $attempt/$MAX_ATTEMPTS); retrying in ${delay}s" >&2
  sleep "$delay"
  attempt=$((attempt + 1))
done

cat "$TMP_OUT"
cat "$TMP_ERR" >&2
exit $rc
