#!/usr/bin/env bash
# crew-codex — forward to the official codex plugin's companion runtime.
# Resolves the runtime through installed_plugins.json so version bumps of
# codex@openai-codex never break the crew agents.
set -euo pipefail

CLAUDE_DIR="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
INSTALLED_JSON="$CLAUDE_DIR/plugins/installed_plugins.json"
CODEX_PLUGIN_ID="codex@openai-codex"

if ! command -v node >/dev/null 2>&1; then
  echo "crew-codex: node is required (the codex companion runtime is a Node script)" >&2
  exit 1
fi

if [[ ! -f "$INSTALLED_JSON" ]]; then
  echo "crew-codex: $INSTALLED_JSON not found — install the official Codex plugin first: /plugin install $CODEX_PLUGIN_ID" >&2
  exit 1
fi

if ! COMPANION_ROOT="$(node -e '
  const fs = require("fs");
  const data = JSON.parse(fs.readFileSync(process.argv[1], "utf8"));
  const entries = (data.plugins || {})[process.argv[2]];
  if (!Array.isArray(entries) || entries.length === 0 || !entries[0].installPath) process.exit(2);
  process.stdout.write(entries[0].installPath);
' "$INSTALLED_JSON" "$CODEX_PLUGIN_ID")"; then
  echo "crew-codex: $CODEX_PLUGIN_ID is not installed — run: /plugin install $CODEX_PLUGIN_ID" >&2
  exit 1
fi

COMPANION="$COMPANION_ROOT/scripts/codex-companion.mjs"
if [[ ! -f "$COMPANION" ]]; then
  echo "crew-codex: companion script missing at $COMPANION — the codex plugin layout changed; update codex-crew's resolver" >&2
  exit 1
fi

# Job state must land in the codex plugin's data dir so /codex:status,
# /codex:result and its SessionEnd cleanup see crew-launched jobs too.
export CLAUDE_PLUGIN_DATA="${CLAUDE_PLUGIN_DATA:-$CLAUDE_DIR/plugins/data/codex-openai-codex}"

# Our own archive — the companion prunes at 50 jobs (deleting logs) and drops
# a session's jobs at SessionEnd, so results are copied somewhere it can't reap.
CREW_ARCHIVE_DIR="${CREW_CODEX_ARCHIVE_DIR:-$CLAUDE_DIR/plugins/data/codex-crew/jobs}"

if [[ "${1:-}" == "--resolve" ]]; then
  echo "$COMPANION"
  exit 0
fi

# ---- await: poll a detached job toward terminal state, token-free ----------
# Claude Code's Bash tool caps a single call at 600s, but codex jobs run for
# hours. Each await call blocks up to --for seconds (default 540, safely under
# that cap) and prints exactly ONE line; the caller loops until it stops
# reporting RUNNING. Polling happens in-shell, so a multi-hour job costs no
# model tokens while it runs. Exit: 0 completed, 1 failed/cancelled,
# 2 job not found, 10 still running (call again).
if [[ "${1:-}" == "await" ]]; then
  shift
  JOB_ID="${1:-}"
  if [[ -z "$JOB_ID" || "$JOB_ID" == --* ]]; then
    echo "crew-codex: await needs a job id — usage: crew-codex await <job-id> [--for <seconds>]" >&2
    exit 2
  fi
  shift

  FOR_SECS=540
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --for) FOR_SECS="${2:-540}"; shift 2 ;;
      *) shift ;;
    esac
  done
  POLL_SECS="${CREW_CODEX_POLL_SECS:-5}"

  deadline=$(( $(date +%s) + FOR_SECS ))
  missing_streak=0
  stale_streak=0

  while :; do
    snap="$(node "$COMPANION" status "$JOB_ID" --json 2>/dev/null || true)"
    parsed="$(printf '%s' "$snap" | python3 -c '
import json, sys
try:
    j = json.load(sys.stdin)["job"]
except Exception:
    print("MISSING\t-\t-\t-\t-")
    raise SystemExit
p = j.get("progressPreview") or []
last = str(p[-1]) if p else "-"
print("\t".join([
    str(j.get("status", "?")),
    str(j.get("elapsed", "?")),
    str(j.get("logFile", "-")),
    last.replace("\t", " ")[:80],
    str(j.get("pid") or "-"),
]))
' 2>/dev/null || printf 'MISSING\t-\t-\t-\t-')"
    IFS=$'\t' read -r jstatus jelapsed jlog jlast jpid <<<"$parsed"

    case "$jstatus" in
      queued|running)
        missing_streak=0
        ;;
      completed|failed|cancelled)
        mkdir -p "$CREW_ARCHIVE_DIR"
        node "$COMPANION" result "$JOB_ID" >"$CREW_ARCHIVE_DIR/$JOB_ID.result.txt" 2>/dev/null || true
        node "$COMPANION" result "$JOB_ID" --json >"$CREW_ARCHIVE_DIR/$JOB_ID.meta.json" 2>/dev/null || true
        if [[ -f "$jlog" ]]; then
          cp -f "$jlog" "$CREW_ARCHIVE_DIR/$JOB_ID.log" 2>/dev/null || true
        fi
        echo "DONE $jstatus | ${jelapsed} | archived: $CREW_ARCHIVE_DIR/$JOB_ID.result.txt"
        if [[ "$jstatus" == "completed" ]]; then exit 0; fi
        exit 1
        ;;
      *)
        # Tolerate a couple of transient unreadable snapshots (state.json is
        # rewritten in place) before declaring the job genuinely gone.
        missing_streak=$(( missing_streak + 1 ))
        if [[ $missing_streak -ge 3 ]]; then
          echo "crew-codex: job $JOB_ID not found in codex state (pruned, session-cleaned, or wrong id)" >&2
          exit 2
        fi
        ;;
    esac

    remaining=$(( deadline - $(date +%s) ))
    if [[ $remaining -le 0 ]]; then
      echo "RUNNING | ${jelapsed} | last: ${jlast}"
      exit 10
    fi

    # Prefer waiting on the job's own process: tail --pid blocks in the kernel
    # and wakes the instant it exits (verified: state.json is already terminal
    # by then). Falls back to polling when the pid is absent or already gone.
    if [[ "$jpid" =~ ^[0-9]+$ ]] && kill -0 "$jpid" 2>/dev/null; then
      stale_streak=0
      timeout "$remaining" tail --pid="$jpid" -f /dev/null 2>/dev/null || true
    else
      if [[ "$jpid" =~ ^[0-9]+$ ]]; then
        # Process is gone but the job never reached a terminal status — this is
        # the signature of a silent death, so say so instead of waiting it out.
        stale_streak=$(( stale_streak + 1 ))
        if [[ $stale_streak -ge 3 ]]; then
          echo "STALE $JOB_ID | ${jelapsed} | process $jpid is gone but status is still '$jstatus' — the job died without reporting; resume it or re-dispatch" >&2
          exit 3
        fi
      fi
      sleep "$POLL_SECS"
    fi
  done
fi

# Bounded retry on model-capacity rejection. The capacity error is an
# admission-time rejection (the turn never starts), so retrying is write-safe.
# Jittered backoff so parallel fan-outs don't thundering-herd the quota window.
# Overridable for tests: CREW_CODEX_RETRY_DELAYS="0 0" collapses the waits.
RETRY_DELAYS=(${CREW_CODEX_RETRY_DELAYS:-5 15 45})
MAX_ATTEMPTS=$(( ${#RETRY_DELAYS[@]} + 1 ))
CAPACITY_PATTERN="at capacity"

TMP_OUT="$(mktemp)" TMP_ERR="$(mktemp)"
trap 'rm -f "$TMP_OUT" "$TMP_ERR"' EXIT

attempt=1
while :; do
  rc=0
  node "$COMPANION" "$@" >"$TMP_OUT" 2>"$TMP_ERR" || rc=$?

  if [[ $rc -eq 0 ]] || ! grep -qi "$CAPACITY_PATTERN" "$TMP_OUT" "$TMP_ERR"; then
    break
  fi

  if [[ $attempt -ge $MAX_ATTEMPTS ]]; then
    echo "crew-codex: model still at capacity after $MAX_ATTEMPTS attempts — giving up" >&2
    break
  fi

  base=${RETRY_DELAYS[$((attempt - 1))]}
  delay=$(( base + (base > 0 ? RANDOM % (base / 2 + 1) : 0) ))
  echo "crew-codex: model at capacity (attempt $attempt/$MAX_ATTEMPTS); retrying in ${delay}s" >&2
  sleep "$delay"
  attempt=$((attempt + 1))
done

cat "$TMP_OUT"
cat "$TMP_ERR" >&2
exit $rc
